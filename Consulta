<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Consulta | Trazabilidad Café</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <header>
    <nav class="nav-extended brown darken-3">
      <div class="nav-wrapper container">
        <a href="index.html" class="brand-logo"><i class="material-icons">coffee_maker</i> Café Trazable</a>
        <a href="#" data-target="mobile-nav" class="sidenav-trigger"><i class="material-icons">menu</i></a>
        <ul id="nav-mobile" class="right hide-on-med-and-down">
          <li><a href="index.html">Inicio</a></li>
          <li><a href="lote.html">Lote</a></li>
          <li class="active"><a href="consulta.html">Consulta</a></li>
        </ul>
      </div>
    </nav>
    <ul class="sidenav" id="mobile-nav">
      <li><a href="index.html"><i class="material-icons">home</i>Inicio</a></li>
      <li><a href="lote.html"><i class="material-icons">inventory_2</i>Lote</a></li>
      <li class="active"><a href="consulta.html"><i class="material-icons">search</i>Consulta</a></li>
    </ul>
  </header>

  <main class="container">
    <section class="row">
      <div class="col s12 m8 offset-m2 l6 offset-l3">
        <div class="card">
          <div class="card-content">
            <span class="card-title">Consultar Lote</span>
            <form id="form-consulta" novalidate>
              <div class="row">
                <div class="input-field col s12">
                  <i class="material-icons prefix">tag</i>
                  <input id="lote" type="text" pattern="^AR-[A-Z]{3}-\d{3}$" class="validate" required>
                  <label for="lote">Número de lote</label>
                  <span class="helper-text" data-error="Formato: AR-CBA-042" data-success="Correcto">Formato: AR-XXX-000</span>
                </div>
              </div>
              <div class="row">
                <div class="input-field col s12">
                  <i class="material-icons prefix">email</i>
                  <input id="email" type="email" class="validate" required>
                  <label for="email">Email</label>
                  <span class="helper-text" data-error="Ingresá un email válido"></span>
                </div>
              </div>
              <div class="row">
                <div class="col s12">
                  <button class="btn waves-effect waves-light brown darken-3" type="submit" style="width: 100%;">
                    Buscar Lote
                    <i class="material-icons right">send</i>
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
</body>
</html>

